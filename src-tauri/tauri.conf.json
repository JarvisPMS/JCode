{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/main/packages/tauri-utils/schema.json",
  "productName": "JCode",
  "version": "0.9.9",
  "identifier": "com.jcode.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "JCode",
        "width": 460,
        "height": 700,
        "minWidth": 360,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; connect-src 'self' https:; font-src 'self'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://jcode-release.oss-cn-hangzhou.aliyuncs.com/updater/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY4QjJCQkFDQkNGNzMyOEUKUldTT012ZThyTHV5K0Ura2psTUpiVy93SGRQNEdpSC9XdzdDcWZaR0xUQ3pucXVFUGJqZ280SWMK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/icon.ico",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true,
        "installerHooks": "installer-hooks.nsh"
      },
      "wix": {
        "dialogImagePath": "icons/icon.ico",
        "bannerPath": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13",
      "hardenedRuntime": true
    }
  }
}
